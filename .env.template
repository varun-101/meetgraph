# ============================================================
# meetgraph — shared env template (native dev AND compose use this;
# config must never fork between them. Copy to .env and fill in.)
# ============================================================

# --- App ---
APP_ENV=dev                                # dev | prod
API_HOST=127.0.0.1
API_PORT=8000
WEB_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-32-bytes-min
GUEST_TOKEN_TTL_MINUTES=240

# --- Postgres (app schema; cognee shares the same instance, own DB) ---
DATABASE_URL=postgresql+asyncpg://meetgraph:meetgraph@localhost:5432/meetgraph
SYNC_DATABASE_URL=postgresql+psycopg://meetgraph:meetgraph@localhost:5432/meetgraph

# --- LiveKit (dev: `livekit-server --dev` predefined credentials) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_WEBHOOK_KEY=devkey                 # webhooks signed with same keypair in dev

# --- Recording / capture ---
RECORDINGS_DIR=./recordings
STT_MODEL=base                             # faster-whisper size (small needs ~2GB free RAM)
STT_COMPUTE_TYPE=int8                      # CPU int8 quantization
STT_DEVICE=cpu

# --- Presenter bot ---
TTS_VOICE=en-US-AriaNeural                 # edge-tts neural voice
PRESENTER_FPS=5                            # screenshare frame rate (slides are static)

# --- cognee: single-Postgres backends (§8) — verified against cognee==1.2.2 ---
# The meetgraph role needs CREATEDB: with access control on, cognee creates a
# database per dataset (physical isolation — this is the tenancy boundary).
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=meetgraph
DB_PASSWORD=meetgraph
DB_NAME=meetgraph_cognee
VECTOR_DB_PROVIDER=pgvector
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=5432
VECTOR_DB_USERNAME=meetgraph
VECTOR_DB_PASSWORD=meetgraph
VECTOR_DB_NAME=meetgraph_cognee
GRAPH_DATABASE_PROVIDER=postgres
GRAPH_DATABASE_HOST=localhost
GRAPH_DATABASE_PORT=5432
GRAPH_DATABASE_USERNAME=meetgraph
GRAPH_DATABASE_PASSWORD=meetgraph
GRAPH_DATABASE_NAME=meetgraph_cognee
CACHE_BACKEND=postgres
# MUST stay true: with it false, datasets= filters are IGNORED at query time
# (isolation would silently break). True is also the default for this backend combo.
ENABLE_BACKEND_ACCESS_CONTROL=true
# Deterministic search (v1.2.0 turned per-turn LLM feedback on by default)
AUTO_FEEDBACK=false
# Skip the ~30s preflight LLM connection test on startup (dev nicety)
COGNEE_SKIP_CONNECTION_TEST=true

# --- LLM: DeepSeek via OpenAI-compatible endpoint (D4) ---
LLM_PROVIDER=custom
LLM_MODEL=deepseek/deepseek-chat
LLM_ENDPOINT=https://api.deepseek.com/v1
LLM_API_KEY=sk-REPLACE-ME
# If cognify structured output misbehaves with DeepSeek, uncomment:
# LLM_INSTRUCTOR_MODE=tool_call

# --- Embeddings: local fastembed (DeepSeek has no embeddings API) ---
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# --- cognee Cloud seam (D2) — leave empty for self-hosted ---
COGNEE_BASE_URL=
COGNEE_API_KEY=

# --- Web (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
