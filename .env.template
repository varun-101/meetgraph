# ============================================================
# meetgraph — shared env template (native dev AND compose use this;
# config must never fork between them. Copy to .env and fill in.)
# ============================================================

# --- App ---
APP_ENV=dev                                # dev | prod
API_HOST=127.0.0.1
API_PORT=8000
WEB_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-32-bytes-min
GUEST_TOKEN_TTL_MINUTES=240

# --- Postgres (app schema; cognee shares the same instance, own DB) ---
DATABASE_URL=postgresql+asyncpg://meetgraph:meetgraph@localhost:5432/meetgraph
SYNC_DATABASE_URL=postgresql+psycopg://meetgraph:meetgraph@localhost:5432/meetgraph

# --- LiveKit (dev: `livekit-server --dev` predefined credentials) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_WEBHOOK_KEY=devkey                 # webhooks signed with same keypair in dev

# --- Recording / capture ---
RECORDINGS_DIR=./recordings
STT_MODEL=small                            # faster-whisper model size
STT_COMPUTE_TYPE=int8                      # CPU int8 quantization
STT_DEVICE=cpu

# --- cognee: single-Postgres backends (§8) ---
# NOTE: exact variable names verified against the pinned cognee version at build
# time — see api/memory/memory_service.py header comment for the pin.
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=meetgraph
DB_PASSWORD=meetgraph
DB_NAME=meetgraph_cognee
VECTOR_DB_PROVIDER=pgvector
GRAPH_DATABASE_PROVIDER=kuzu

# --- LLM: DeepSeek via OpenAI-compatible endpoint (D4) ---
LLM_PROVIDER=custom
LLM_MODEL=deepseek/deepseek-chat
LLM_ENDPOINT=https://api.deepseek.com/v1
LLM_API_KEY=sk-REPLACE-ME

# --- Embeddings: local fastembed (DeepSeek has no embeddings API) ---
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# --- cognee Cloud seam (D2) — leave empty for self-hosted ---
COGNEE_BASE_URL=
COGNEE_API_KEY=

# --- Web (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
